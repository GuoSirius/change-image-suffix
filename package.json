{
  "name": "change-image-suffix",
  "version": "2.1.16",
  "type": "module",
  "description": "批量转换图片格式的CLI工具，支持递归搜索、深度限制、指定后缀、Windows右键菜单等功能",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "scripts/postinstall.cjs",
    "scripts/preuninstall.cjs"
  ],
  "bin": {
    "change-image-suffix": "./dist/index.js",
    "cis": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc",
    "dev": "tsc --watch",
    "postinstall": "node scripts/postinstall.cjs",
    "preuninstall": "node scripts/preuninstall.cjs",
    "prepublishOnly": "npm run clean && npm run build",
    "release": "node scripts/release.cjs",
    "release:patch": "node scripts/release.cjs --patch",
    "release:minor": "node scripts/release.cjs --minor",
    "release:major": "node scripts/release.cjs --major",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "image",
    "converter",
    "webp",
    "png",
    "jpg",
    "batch",
    "sharp",
    "context-menu"
  ],
  "author": "siriussupreme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GuoSirius/change-image-suffix.git"
  },
  "bugs": {
    "url": "https://github.com/GuoSirius/change-image-suffix/issues"
  },
  "homepage": "https://github.com/GuoSirius/change-image-suffix#readme",
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@types/node": "^25.9.1",
    "enquirer": "^2.4.1",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
